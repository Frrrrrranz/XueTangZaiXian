# DeepSeek API 配置
# 使用前请将此文件复制为 .env，并填写真实的 API Key
# 注意：.env 文件已被 .gitignore 忽略，切勿将真实 Key 提交到仓库

# 必填：DeepSeek API Key（在 https://platform.deepseek.com 获取）
VITE_DEEPSEEK_API_KEY=your_api_key_here

# 可选：API 地址（默认为官方地址）
# VITE_DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions

# 可选：使用的模型（默认 deepseek-v4-flash）
# VITE_DEEPSEEK_MODEL=deepseek-v4-flash
