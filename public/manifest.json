{
  "manifest_version": 3,
  "name": "学堂在线刷课助手",
  "version": "1.0.0",
  "description": "学堂在线 AI 自动答题插件，支持 DeepSeek 智能作答、题目收集与 Markdown 导出复习。",
  "permissions": [
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "http://api.tikuhai.com/*",
    "http://cx.icodef.com/*",
    "https://tk.enncy.cn/*",
    "https://api.muketool.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.xuetangx.com/*",
        "*://*.chaoxing.com/*",
        "*://*.xuexitong.com/*"
      ],
      "js": ["assets/content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  }
}
